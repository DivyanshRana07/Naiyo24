APP_HOST=127.0.0.1
APP_PORT=8000

# --- Database configuration ---
# If DATABASE_URL is set, it is used directly.
# Example PostgreSQL URL:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/business_tools
DATABASE_URL=sqlite:///./business_tools.db

# Fallback credential-based values (used when DATABASE_URL is empty)
DB_DIALECT=sqlite
DB_DRIVER=psycopg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=business_tools.db
DB_USER=postgres
DB_PASSWORD=postgres

SECRET_KEY=my_super_secret_key_2026_invoice_project
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
